# ============================================================
#  Flux Backend — variables de entorno requeridas
#  Copia este archivo como .env y completa los valores reales.
#  NUNCA commitees .env con valores reales.
# ============================================================

# Server
PORT=3000
NODE_ENV=development

# Database SQLite (archivo local)
DATABASE_URL="file:./flux.db"

# JWT — genera uno seguro con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=REEMPLAZA_CON_UN_SECRET_SEGURO_DE_64_BYTES
JWT_EXPIRE=7d

# CORS — URL del frontend en producción
FRONTEND_URL=http://localhost:5173

# Orion Engine (Rust)
ORION_ENGINE_URL=http://localhost:4000

# Google / Gemini — obtén tus claves en console.cloud.google.com
GEMINI_API_KEY=
GOOGLE_CLOUD_API_KEY=
GOOGLE_APPLICATION_CREDENTIALS=./ruta/a/service-account.json
