{
  "name": "orion-backend",
  "version": "1.0.0-beta.1",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "build:exe": "npm run build && pkg dist/index.js --target node18-win-x64 --output ../flux-engine/bin/flux-backend.exe --assets \"node_modules/.prisma/client/query_engine*\"",
    "start": "node dist/index.js",
    "prisma:migrate": "prisma migrate dev",
    "prisma:generate": "prisma generate",
    "prisma:studio": "prisma studio"
  },
  "pkg": {
    "assets": [
      "node_modules/.prisma/client/query_engine*",
      "node_modules/@prisma/client/**/*.node",
      "node_modules/prisma/build/index.js"
    ],
    "scripts": [
      "dist/**/*.js"
    ]
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "dependencies": {
    "@google-cloud/text-to-speech": "^6.4.0",
    "@google/generative-ai": "^0.24.1",
    "@prisma/client": "^6.19.1",
    "bcrypt": "^6.0.0",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "express-rate-limit": "^8.2.2",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/express": "^4.17.25",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.16.5",
    "@yao-pkg/pkg": "^5.12.0",
    "prisma": "^6.19.1",
    "tsx": "^4.21.0",
    "typescript": "^5.8.3"
  }
}
